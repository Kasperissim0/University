#!/bin/bash

# TODO Should Probably Make This A Git Directory / Submodule

# --- COLORS ---
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

VERSION="3.5.1"
START_TIME=$(date +%s)

# --- TERMINAL WIDTH ---
TERM_WIDTH=$(tput cols 2>/dev/null || echo 80)

# --- CPU DETECTION ---
get_cores() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sysctl -n hw.ncpu
    else
        nproc 2>/dev/null || echo 2
    fi
}

# Centered block (pads all lines equally to maintain internal formatting)
center_block() {
    local block="$1"
    local width=${TERM_WIDTH:-80}
    
    # Find the maximum line length in the block (ignoring ANSI codes)
    local max_len=0
    while IFS= read -r line; do
        local clean_line
        clean_line=$(echo -e "$line" | sed 's/\x1b\[[0-9;]*m//g')
        local len=${#clean_line}
        if (( len > max_len )); then
            max_len=$len
        fi
    done <<< "$block"
    
    # Calculate uniform padding
    local padding=$(( (width - max_len) / 2 ))
    [[ $padding -lt 0 ]] && padding=0
    local pad_str
    pad_str=$(printf "%*s" "$padding" "")
    
    # Print each line with the exact same padding
    while IFS= read -r line; do
        echo -e "${pad_str}${line}"
    done <<< "$block"
}

# Centered banner with dashes: -------  LABEL  -------
banner() {
    $QUIET_MODE && return
    local label="$1"
    local color="$2"
    local width=${TERM_WIDTH:-80}
    local label_len=${#label}
    local padding=4
    local total_dashes=$(( width - label_len - padding ))

    if [ $total_dashes -lt 2 ]; then
        log "${color}${BOLD}${label}${NC}"
        return
    fi

    local left=$(( total_dashes / 2 ))
    local right=$(( total_dashes - left ))
    local d_left
    d_left=$(printf "%${left}s" | tr ' ' '-')
    local d_right
    d_right=$(printf "%${right}s" | tr ' ' '-')

    log ""
    log "${color}${BOLD}${d_left}  ${label}  ${d_right}${NC}"
    log ""
}

# --- USAGE ---
usage() {
    echo -e "${BOLD}${RED}COMMAND:${NC}"
    echo -e "${BOLD}${CYAN}Unit Test Utility${NC} (utu) v ${BOLD}${RED}${VERSION}${NC}"
    echo ""
    echo -e "${BOLD}${RED}USAGE:${NC}"
    echo -e "  utu [OPTIONS]"
    echo ""
    echo -e "${BOLD}${RED}OPTIONS:${NC}"
    echo -e "  -v          Verbose: show full output and examples in help"
    echo -e "  -n <nums>   Run only tests by number, comma-separated (e.g. -n 3,5,8)"
    echo -e "  -i <nums>   Ignore tests by number, comma-separated (e.g. -i 3,5,8)"
    echo -e "  -f <0|1>    Result filter: 0 for ${RED}FAILED${NC}, 1 for ${GREEN}PASSED${NC}"
    echo -e "  -l <file>   Log results to <file>"
    echo -e "  -j          JSON output: print results in JSON format at the end"
    echo -e "  -s          Per-file compile status + summary (no test output)"
    echo -e "  -S          Summary only: progress bar during compile, summary at end"
    echo -e "  -e          Execute: compile only missing files, then run all requested"
    echo -e "  -c          Compile: compile ONLY missing files, then STOP (no execution). Recompiles regardless of changes."
    echo -e "  -E          Strict Execute: skip non-compiled files, run only existing binaries"
    echo -e "  -p          Parallel: use optimal cores for compilation"
    echo -e "  -o          Optimal: Smart rebuild (only if changed) + Parallel"
    echo -e "  -t          Test (dry run): show what would be done without executing"
    echo -e "  -q          Quiet: suppress all output except results or errors"
    echo -e "  -b          Brief summary: hide file lists (Compiled/Failed) in the final summary"
    echo -e "  -H          Hide: hides the summary at the end"
    echo -e "  -d          Delete: deletes the ${EXEC_DIR} directory after execution"
    echo -e "  -r          Recursive search: finds tests in subdirectories"
    echo ""
    echo -e "  -V          Show version"
    echo -e "  -h          Show this help message (run with -v to see usage examples)"
    echo -e "  -u          Update: runs install.sh from script directory"
    
    if $VERBOSE; then
        echo ""
        echo -e "${BOLD}${RED}EXAMPLES:${NC}"
        echo -e "  utu -of 0              # Rebuild only changed files, run in parallel, show only failures"
        echo -e "  utu -vn 1,3,5          # Run tests 1, 3, and 5 with full output including print statements"
        echo -e "  utu -oqj               # Optimal build, run quietly, output final results in JSON format"
        echo -e "  utu -EHi 2,4           # Run only existing binaries, skip tests 2 and 4, hide the final summary"
        echo -e "  utu -cpl build.log     # Force recompile all missing files in parallel, log the output to a file"
        echo -e "  utu -ton 10            # Dry run: show what would happen when optimally running test 10"
        echo -e "  utu -odS               # Build and run optimally, then delete the tests folder, showing only a progress bar"
        echo -e "  utu -oSqbrf 0          # Optimal recursive build, run quietly, show only failed execution output, brief summary (no file lists)"
    fi
    exit 0
}

# --- PARSE ARGS ---
NUMBERS=""
IGNORE_NUMBERS=""
FAILED_ONLY=false
PASSED_ONLY=false
RECURSIVE=false
VERBOSE=false
LOGFILE=""
JSON_OUTPUT=false
SUMMARY_ONLY=false
COMPACT=false
REMOVE_TESTS=false
HIDE_SUMMARY=false
EXEC_ONLY=false
COMPILE_ONLY=false
STRICT_EXEC=false
DRY_RUN=false
QUIET_MODE=false
JOBS=1
OPTIMAL=false
BRIEF_SUMMARY=false
SHOW_HELP=false


EXEC_DIR='executables/'


while getopts "n:i:f:rdvl:sVShuHeEctopjqb" opt; do
    case $opt in
        n)
            NUMBERS="$OPTARG"
            while [[ $OPTIND -le $# && ! "${!OPTIND}" =~ ^- ]]; do
                NUMBERS+="${!OPTIND}"
                OPTIND=$((OPTIND + 1))
            done
            ;;
        i)
            IGNORE_NUMBERS="$OPTARG"
            while [[ $OPTIND -le $# && ! "${!OPTIND}" =~ ^- ]]; do
                IGNORE_NUMBERS+="${!OPTIND}"
                OPTIND=$((OPTIND + 1))
            done
            ;;
        f)
            if [[ "$OPTARG" == "0" ]]; then FAILED_ONLY=true;
            elif [[ "$OPTARG" == "1" ]]; then PASSED_ONLY=true;
            else
                echo -e "${RED}❌ Invalid result filter: $OPTARG (use 0 or 1)${NC}"
                exit 1
            fi
            ;;
        r) RECURSIVE=true ;;
        d) REMOVE_TESTS=true ;;
        v) VERBOSE=true ;;
        l) LOGFILE="$OPTARG" ;;
        s) COMPACT=true ;;
        S) SUMMARY_ONLY=true ;;
        e) EXEC_ONLY=true ;;
        c) COMPILE_ONLY=true ;;
        E) STRICT_EXEC=true ;;
        H) HIDE_SUMMARY=true ;;
        t) DRY_RUN=true ;;
        q) QUIET_MODE=true ;;
        o) OPTIMAL=true; JOBS=$(get_cores) ;;
        p) JOBS=$(get_cores) ;;
        b) BRIEF_SUMMARY=true ;;
        j) JSON_OUTPUT=true ;;
        V) echo -e "😎 Latest Version: ${RED}$VERSION${NC}"; exit 0 ;;
        u)
            SOURCE="${BASH_SOURCE[0]}"
            while [ -L "$SOURCE" ]; do
                DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)
                SOURCE=$(readlink "$SOURCE")
                [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
            done
            SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)

            if [[ -f "$SCRIPT_DIR/install.sh" ]]; then
                echo -e "${CYAN}Running update for utu v${VERSION} from $SCRIPT_DIR/install.sh...${NC}"
                bash "$SCRIPT_DIR/install.sh"
                exit 0
            else
                echo -e "${RED}❌ update failed: install.sh not found in $SCRIPT_DIR${NC}"
                exit 1
            fi
            ;;
        h) SHOW_HELP=true ;;
        *) SHOW_HELP=true ;;
    esac
done

[[ $SHOW_HELP == true ]] && usage

# --- MUTUAL EXCLUSIVITY CHECK ---
MODES_COUNT=0
$EXEC_ONLY && MODES_COUNT=$((MODES_COUNT + 1))
$COMPILE_ONLY && MODES_COUNT=$((MODES_COUNT + 1))
$STRICT_EXEC && MODES_COUNT=$((MODES_COUNT + 1))
$OPTIMAL && MODES_COUNT=$((MODES_COUNT + 1))

if [[ $MODES_COUNT -gt 1 ]]; then
    echo -e "${RED}❌ Conflict: Choose only one mode from -e, -c, -E, or -o.${NC}"
    exit 1
fi

if $FAILED_ONLY && $PASSED_ONLY; then
    echo -e "${RED}❌ Conflict: -f 0 and -f 1 are mutually exclusive.${NC}"
    exit 1
fi

# --- VERBOSE EXPLANATIONS ---
if $VERBOSE && ! $QUIET_MODE; then
    if $OPTIMAL; then
        echo -e "${GREEN}✨ Optimal mode: ${NC}Smart rebuilding changed files and using ${RED}$JOBS${NC} parallel jobs."
    elif [[ $JOBS -gt 1 ]]; then
        echo -e "${YELLOW}🚀 Parallel mode: ${NC}Using ${RED}$JOBS${NC} parallel jobs for compilation."
    fi
fi

# --- NUMBER FILTER ---
matches_filter() {
    local tname="$1"
    local num
    num=$(echo "$tname" | grep -oE '[0-9]+$')

    if [[ -n "$IGNORE_NUMBERS" ]]; then
        local cleaned_ignore="${IGNORE_NUMBERS// /}"
        IFS=', ' read -ra INUMS <<< "$cleaned_ignore"
        for n in "${INUMS[@]}"; do
            [[ "$num" == "$n" ]] && return 1
        done
    fi

    [[ -z "$NUMBERS" ]] && return 0

    local cleaned_nums="${NUMBERS// /}"
    IFS=', ' read -ra NUMS <<< "$cleaned_nums"
    for n in "${NUMS[@]}"; do
        [[ "$num" == "$n" ]] && return 0
    done
    return 1
}

# --- LOGGING ---
log() {
    if ! $QUIET_MODE; then
        echo -e "$1"
    fi
    if [[ -n "$LOGFILE" ]]; then
        echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g' >> "$LOGFILE"
    fi
}

err_log() {
    echo -e "$1"
    if [[ -n "$LOGFILE" ]]; then
        echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g' >> "$LOGFILE"
    fi
}

# --- INIT LOGFILE ---
if [[ -n "$LOGFILE" ]]; then
    echo "utu v${VERSION} @ $(date '+%Y-%m-%d %H:%M:%S')" > "$LOGFILE"
    echo "Numbers: ${NUMBERS:-all} | Ignore: ${IGNORE_NUMBERS:-none} | failed-only: $FAILED_ONLY | passed-only: $PASSED_ONLY | verbose: $VERBOSE" >> "$LOGFILE"
    printf '%*s\n' "$TERM_WIDTH" '' | tr ' ' '=' >> "$LOGFILE"
fi

# --- FIND TESTS ---
if $RECURSIVE; then
    while IFS= read -r -d '' file; do
        FILES+=("$file")
    done < <(find . -maxdepth 4 -name "utest*.cpp" -print0)
    if [[ ${#FILES[@]} -eq 0 ]]; then
        echo -e "${RED}❌ No utest*.cpp files found in current or subdirectories.${NC}"
        exit 1
    fi
else
    SEARCH_DIR="$PWD"
    while [[ "$SEARCH_DIR" != "/" ]]; do
        if ls "$SEARCH_DIR"/utest*.cpp &>/dev/null; then break; fi
        SEARCH_DIR="$(dirname "$SEARCH_DIR")"
    done

    if ! ls "$SEARCH_DIR"/utest*.cpp &>/dev/null; then
        echo -e "${RED}❌ No utest*.cpp files found in current or parent directories.${NC}"
        exit 1
    fi

    cd "$SEARCH_DIR" || exit 1
    FILES=(./utest*.cpp)
fi

[[ $DRY_RUN == false ]] && mkdir -p "${EXEC_DIR}"

FLAGS="-fcolor-diagnostics -fansi-escape-codes -std=c++23 -g -I."

# --- COUNT TOTAL FILES TO PROCESS ---
TOTAL_FILES=0
for f in "${FILES[@]}"; do
    TNAME=$(basename "$f" .cpp)
    matches_filter "$TNAME" && TOTAL_FILES=$((TOTAL_FILES + 1))
done

# ============================================================
#  COMPILE PHASE
# ============================================================
COMPILE_OK=0
COMPILE_ERRORS=0
COMPILE_SKIPPED=0
COMPILE_OK_LIST=()
COMPILE_FAIL_LIST=()

# Aggregated Stats
STAT_TC_TOTAL=0
STAT_TC_PASS=0
STAT_TC_FAIL=0
STAT_TC_SKIP=0
STAT_AS_PASS=0
STAT_AS_FAIL=0

MISSING_BINARIES=()
FILES_TO_COMPILE=()

# --- SMART REBUILD CHECK ---
for f in "${FILES[@]}"; do
    TNAME=$(basename "$f" .cpp)
    if ! matches_filter "$TNAME"; then
        COMPILE_SKIPPED=$((COMPILE_SKIPPED + 1))
        continue
    fi

    if [[ ! -x "${EXEC_DIR}${TNAME}" ]]; then
        MISSING_BINARIES+=("$TNAME")
        if ! $STRICT_EXEC; then
            FILES_TO_COMPILE+=("$f")
        fi
    else
        # Check if rebuild needed (only if OPTIMAL or EXEC_ONLY)
        REASON=""
        if $COMPILE_ONLY; then
            REASON="Force recompile (-c)"
            FILES_TO_COMPILE+=("$f")
        elif $OPTIMAL || $EXEC_ONLY; then
            if [[ ! -x "${EXEC_DIR}${TNAME}" ]]; then REASON="Binary missing"
            elif [[ "$f" -nt "${EXEC_DIR}${TNAME}" ]]; then REASON="Source file changed"
            else
                for h in *.h *.hpp; do
                    if [[ -e "$h" && "$h" -nt "${EXEC_DIR}${TNAME}" ]]; then
                        REASON="Header '$h' changed"
                        break
                    fi
                done
            fi

            if [[ -n "$REASON" ]]; then
                FILES_TO_COMPILE+=("$f")
                if $VERBOSE; then
                    echo -e "${CYAN}  ▸ Smart Rebuild: $f ($REASON)${NC}"
                fi
            else
                if $VERBOSE; then
                    echo -e "${DIM}  ▸ Skipping $f: up-to-date${NC}"
                fi
            fi
        elif ! $STRICT_EXEC && ! $COMPILE_ONLY; then
            # Default behavior (recompile all requested)
            FILES_TO_COMPILE+=("$f")
        fi
        
        # Suggestion logic for Strict Execute or basic run
        if $STRICT_EXEC || [[ $MODES_COUNT -eq 0 ]]; then
            if [[ -z "$REASON" ]]; then
                # Recalculate reason if not already done
                if [[ "$f" -nt "${EXEC_DIR}${TNAME}" ]]; then REASON="Source file changed"
                else
                    for h in *.h *.hpp; do
                        if [[ -e "$h" && "$h" -nt "${EXEC_DIR}${TNAME}" ]]; then
                            REASON="Header '$h' changed"
                            break
                        fi
                    done
                fi
            fi

            if $VERBOSE && [[ -n "$REASON" ]]; then
                echo -e "${YELLOW}💡 Suggestion: $f has changes ($REASON). Run with -o to rebuild.${NC}"
            fi
        fi
    fi
done

# Inform about missing binaries with proper list formatting (only if verbose)
if [[ ${#MISSING_BINARIES[@]} -gt 0 ]] && $VERBOSE; then
    if $STRICT_EXEC; then
        echo -e "${RED}⚠️  Cannot execute — not compiled:${NC}"
        for mb in "${MISSING_BINARIES[@]}"; do
            echo -e "  ${DIM}-${NC} ${RED}${mb}${NC}"
        done
        # echo -e "${RED}   Only running available binaries (-E).${NC}"
    elif $EXEC_ONLY || $COMPILE_ONLY; then
        echo -e "${YELLOW}⚙️  Missing binaries will be compiled:${NC}"
        for mb in "${MISSING_BINARIES[@]}"; do
            echo -e "  ${DIM}-${NC} ${YELLOW}${mb}${NC}"
        done
        # echo ""
    fi
fi

if [[ ${#FILES_TO_COMPILE[@]} -gt 0 ]]; then
    if ! $SUMMARY_ONLY; then
        banner "COMPILING TEST(S)" "$CYAN"
    fi

    TOTAL_TO_COMPILE=${#FILES_TO_COMPILE[@]}
    CURRENT=0
    
    # Create temp dir for parallel output buffering
    TEMP_OUT_DIR=$(mktemp -d)
    
    for f in "${FILES_TO_COMPILE[@]}"; do
        TNAME=$(basename "$f" .cpp)
        TDIR=$(dirname "$f")
        CURRENT=$((CURRENT + 1))

        if $DRY_RUN; then
            log "  ${DIM}[DRY RUN] Would compile $f -> ${EXEC_DIR}${TNAME}${NC}"
            COMPILE_OK=$((COMPILE_OK + 1))
            COMPILE_OK_LIST+=("$f")
            continue
        fi

        EXTRA_SOURCES=""
        [[ -f "miniatur.cpp" ]] && EXTRA_SOURCES="miniatur.cpp"
        [[ -f "$TDIR/miniatur.cpp" ]] && [[ "$TDIR" != "." ]] && EXTRA_SOURCES="$TDIR/miniatur.cpp"

        # Compilation task function
        run_compile() {
            local file="$1"
            local target="$2"
            local idx="$3"
            local extra="$4"
            local tdir="$5"
            local out_file="$TEMP_OUT_DIR/out_$idx"
            
            rm -f "${EXEC_DIR}${target}"
            clang++ $FLAGS -I"$tdir" "$file" $extra -o "${EXEC_DIR}${target}" > "$out_file" 2>&1
            echo $? > "$TEMP_OUT_DIR/res_$idx"
        }

        if [[ $JOBS -gt 1 ]]; then
            run_compile "$f" "$TNAME" "$CURRENT" "$EXTRA_SOURCES" "$TDIR" &
            
            # Job control: wait if we hit the limit
            while [[ $(jobs -r | wc -l) -ge $JOBS ]]; do
                sleep 0.1
            done
        else
            # Sequential mode (original logic for better UX)
            if $SUMMARY_ONLY; then
                printf "\r${CYAN}==> Compiling [${CURRENT}/${TOTAL_TO_COMPILE}] %-30s${NC}" "$f"
            elif $COMPACT; then
                if ! $QUIET_MODE; then
                    printf "${CYAN}  ▸ ⚙️ COMPILING: ${BOLD}%-30s${NC}" "$f"
                fi
            else
                log "${CYAN}${BOLD}▸ ⚙️ COMPILING: $f${NC}"
            fi

            rm -f "${EXEC_DIR}${TNAME}"
            COMPILE_OUT=$(clang++ $FLAGS -I"$TDIR" "$f" $EXTRA_SOURCES -o "${EXEC_DIR}${TNAME}" 2>&1)
            RES=$?
            
            if [ $RES -ne 0 ]; then
                COMPILE_ERRORS=$((COMPILE_ERRORS + 1))
                COMPILE_FAIL_LIST+=("$f")
                if $SUMMARY_ONLY; then :;
                elif $COMPACT; then
                    if ! $QUIET_MODE; then
                        FILE_ERRORS=$(echo "$COMPILE_OUT" | grep -c 'error:')
                        echo -e "  ${RED}❌ ${FILE_ERRORS} error(s)${NC}"
                    fi
                else
                    log "  ${RED}${BOLD}❌ FAILED TO COMPILE${NC}"
                    log "  ${BOLD}${YELLOW}🔧 Problem(s):${NC}"
                    log "$COMPILE_OUT"
                    log ""
                fi
            else
                COMPILE_OK=$((COMPILE_OK + 1))
                COMPILE_OK_LIST+=("$f")
                if $COMPACT; then
                    if ! $QUIET_MODE; then
                        echo -e "  ${GREEN}✅ COMPILED SUCCESSFULLY${NC}"
                    fi
                elif ! $SUMMARY_ONLY; then
                    log "${GREEN}  ✅ COMPILED SUCCESSFULLY${NC}"
                fi
            fi
        fi
    done

    # Wait for all parallel jobs and process their results
    if [[ $JOBS -gt 1 && $DRY_RUN == false ]]; then
        wait
        for i in $(seq 1 "$TOTAL_TO_COMPILE"); do
            f="${FILES_TO_COMPILE[$((i-1))]}"
            TNAME=$(basename "$f" .cpp)
            RES=$(cat "$TEMP_OUT_DIR/res_$i")
            COMPILE_OUT=$(cat "$TEMP_OUT_DIR/out_$i")

            if ! $SUMMARY_ONLY && ! $QUIET_MODE; then
                if $COMPACT; then
                    printf "${CYAN}  ▸ ⚙️ COMPILING: ${BOLD}%-30s${NC}" "$f"
                else
                    log "${CYAN}${BOLD}▸ ⚙️ COMPILING: $f${NC}"
                fi
            fi

            if [ "$RES" -ne 0 ]; then
                COMPILE_ERRORS=$((COMPILE_ERRORS + 1))
                COMPILE_FAIL_LIST+=("$f")
                if ! $SUMMARY_ONLY; then
                    if $COMPACT; then
                        if ! $QUIET_MODE; then
                            FILE_ERRORS=$(echo "$COMPILE_OUT" | grep -c 'error:')
                            echo -e "  ${RED}❌ ${FILE_ERRORS} error(s)${NC}"
                        fi
                    else
                        log "  ${RED}${BOLD}❌ FAILED TO COMPILE${NC}"
                        log "  ${BOLD}${YELLOW}🔧 Problem(s):${NC}"
                        log "$COMPILE_OUT"
                        log ""
                    fi
                fi
            else
                COMPILE_OK=$((COMPILE_OK + 1))
                COMPILE_OK_LIST+=("$f")
                if ! $SUMMARY_ONLY && ! $QUIET_MODE; then
                    if $COMPACT; then
                        echo -e "  ${GREEN}✅ COMPILED SUCCESSFULLY${NC}"
                    else
                        log "${GREEN}  ✅ COMPILED SUCCESSFULLY${NC}"
                    fi
                fi
            fi
        done
    fi
    rm -rf "$TEMP_OUT_DIR"

    if $SUMMARY_ONLY; then
        printf "\r%-${TERM_WIDTH}s\r" ""
    fi
fi

# ============================================================
#  RUN PHASE
# ============================================================
if ! $COMPILE_ONLY; then
    if ! $SUMMARY_ONLY && ! $COMPACT; then
        banner "RUNNING TEST(S)" "$YELLOW"
    fi

PASS=0
FAIL=0
RUN_TOTAL=0
RUN_CURRENT=0
FAILED_LIST=()
PASS_LIST=()
SLOWEST_TESTS=()

TESTS_TO_RUN=()
for t in "${EXEC_DIR}"utest*; do
    [[ -d "$t" ]] && continue
    TNAME=$(basename "$t")
    if matches_filter "$TNAME" && [ -x "$t" ]; then
        TESTS_TO_RUN+=("$t")
    fi
done

RUN_TOTAL=${#TESTS_TO_RUN[@]}
CURRENT=0
for t in "${TESTS_TO_RUN[@]}"; do
    TNAME=$(basename "$t")
    CURRENT=$((CURRENT + 1))

    # Trace source path for reporting
    TPATH="$TNAME"
    for f in "${FILES[@]}"; do
        if [[ "$(basename "$f" .cpp)" == "$TNAME" ]]; then
            TPATH="$f"
            break
        fi
    done

    if $DRY_RUN; then
        log "  ${DIM}[DRY RUN] Would execute ${EXEC_DIR}${TNAME}${NC}"
        PASS=$((PASS + 1))
        PASS_LIST+=("$TPATH")
        continue
    fi

    if $SUMMARY_ONLY; then        printf "\r${YELLOW}==> Running   [${CURRENT}/${RUN_TOTAL}] %-30s${NC}" "$TNAME"
    fi

    TEST_START=$(date +%s)
    OUTPUT_RAW=$(./"$t" 2>&1)
    EXIT_CODE=$?
    TEST_END=$(date +%s)
    TEST_DUR=$((TEST_END - TEST_START))
    
    # Store for slowest tracking (Duration:Name format for easy sorting)
    SLOWEST_TESTS+=("$TEST_DUR:$TNAME")

    # Aggregate stats from raw output before stripping
    TC_LINE=$(echo "$OUTPUT_RAW" | grep -i "test cases:")
    AS_LINE=$(echo "$OUTPUT_RAW" | grep -i "assertions:")

    if [[ -n "$TC_LINE" ]]; then
        STAT_TC_TOTAL=$((STAT_TC_TOTAL + $(echo "$TC_LINE" | sed -E 's/.*test cases: +([0-9]+).*/\1/')))
        STAT_TC_PASS=$((STAT_TC_PASS   + $(echo "$TC_LINE" | sed -E 's/.*\| +([0-9]+) passed.*/\1/')))
        STAT_TC_FAIL=$((STAT_TC_FAIL   + $(echo "$TC_LINE" | sed -E 's/.*\| +([0-9]+) failed.*/\1/')))
        STAT_TC_SKIP=$((STAT_TC_SKIP   + $(echo "$TC_LINE" | sed -E 's/.*\| +([0-9]+) skipped.*/\1/')))
    fi
    if [[ -n "$AS_LINE" ]]; then
        STAT_AS_PASS=$((STAT_AS_PASS + $(echo "$AS_LINE" | sed -E 's/.*\| +([0-9]+) passed.*/\1/')))
        STAT_AS_FAIL=$((STAT_AS_FAIL + $(echo "$AS_LINE" | sed -E 's/.*\| +([0-9]+) failed.*/\1/')))
    fi

    # Strip doctest noise
    OUTPUT=$(echo "$OUTPUT_RAW" | sed 's/\[doctest\] //g' | grep -vE "doctest version is|run with \"--help\" for options|^[=-]{5,}|^[a-zA-Z0-9._-]+\.cpp:[0-9]+:$" | grep .)
    FAILED_LINES=$(echo "$OUTPUT" | grep -iE "FAILED\!|ERROR|❌|[1-9][0-9]* (failed|error)" | grep .)

    if [[ $EXIT_CODE -ne 0 || -n "$FAILED_LINES" ]]; then
        FAIL=$((FAIL + 1))
        FAILED_LIST+=("$TPATH")
        if ! echo "$OUTPUT" | grep -q "Status:"; then
            OUTPUT="${OUTPUT}\nStatus: FAILURE!"
        fi
        IS_FAILURE=true
    else
        PASS=$((PASS + 1))
        PASS_LIST+=("$TPATH")
        IS_FAILURE=false
    fi

    colorize_text() {
        local text="$1"
        text=$(echo -e "$text" | sed -E "s/(TEST CASE:)/\\${RED}\1\\${NC}/g")
        text=$(echo -e "$text" | sed -E "s/(FATAL ERROR|ERROR:)/\\${RED}\1\\${NC}/g")
        text=$(echo -e "$text" | sed -E "s/([0-9]+ passed)/\\${GREEN}\1\\${NC}/g")
        text=$(echo -e "$text" | sed -E "s/([0-9]+ failed)/\\${RED}\1\\${NC}/g")
        text=$(echo -e "$text" | sed -E "s/([0-9]+ skipped)/\\${DIM}\1\\${NC}/g")
        text=$(echo -e "$text" | sed "s/Status: SUCCESS!/Status: \\${GREEN}✅ SUCCESS\\${NC}/g")
        text=$(echo -e "$text" | sed "s/Status: FAILURE!/Status: \\${RED}❌ FAILURE\\${NC}/g")

        # Simple Diff View in Verbose
        if $VERBOSE; then
            text=$(echo -e "$text" | sed -E "s/(with expansion:)/\\${CYAN}\1\\${NC}/g")
            # Attempt to color the expanded values if they are simple numbers
            text=$(echo -e "$text" | sed -E "s/( +)([0-9]+)( == )([0-9]+)/  \\${GREEN}\2\\${NC} \\${DIM}==\\${NC} \\${RED}\4\\${NC}/g")
        fi
        echo -e "$text"
    }
    OUTPUT=$(colorize_text "$OUTPUT")
    FAILED_LINES=$(colorize_text "$FAILED_LINES")

    if $IS_FAILURE; then
        if ! $SUMMARY_ONLY && ! $COMPACT && ! $PASSED_ONLY; then
            err_log "${YELLOW}${BOLD}▸ 📝 EXECUTING: $TNAME${NC}"
            if $VERBOSE; then
                echo -e "$OUTPUT" | sed 's/^/  /' | while IFS= read -r line; do err_log "$line"; done
            else
                echo "$FAILED_LINES" | while IFS= read -r line; do
                    err_log "${NC}  >> $line${NC}"
                done
                echo -e "$OUTPUT" | grep "Status:" | while IFS= read -r line; do
                    err_log "${NC}  >> $line${NC}"
                done
            fi
            log ""
        fi
    else
        if ! $SUMMARY_ONLY && ! $COMPACT && ! $FAILED_ONLY; then
            log "${YELLOW}${BOLD}▸ 📝 EXECUTING: $TNAME${NC}"
            if $VERBOSE; then
                echo -e "$OUTPUT" | sed 's/^/  /' | while IFS= read -r line; do log "$line"; done
            else
                echo -e "$OUTPUT" | grep -iE "test cases:|assertions:|Status:" | while IFS= read -r line; do
                    log "${NC}  >> $line${NC}"
                done
            fi
            log ""
        fi
    fi
done

    if $SUMMARY_ONLY; then
        printf "\r%-${TERM_WIDTH}s\r" ""
    fi
fi
if ! $HIDE_SUMMARY; then
    banner "SUMMARY" "$GREEN"

    # Helper function for files: 1 inline, 2+ bulleted
    format_file_list() {
        local label="$1"
        local color="$2"
        local logger="${3:-log}"
        shift 3
        local arr=("$@")

        if [[ ${#arr[@]} -eq 0 ]]; then
            return
        elif [[ ${#arr[@]} -eq 1 ]]; then
            $logger "    ${label} ${color}${arr[0]}${NC}"
        else
            $logger "    ${label}"
            for item in "${arr[@]}"; do
                $logger "      ${DIM}-${NC} ${color}${item}${NC}"
            done
        fi
    }

    # 1. Compilation
    if ! $QUIET_MODE || [[ ${#COMPILE_FAIL_LIST[@]} -gt 0 ]]; then
        if ! $BRIEF_SUMMARY; then
            err_log "  ${BOLD}🔨 Compilation:${NC}"
            if [[ ${#COMPILE_OK_LIST[@]} -gt 0 ]] && ! $QUIET_MODE && ! $FAILED_ONLY; then
                format_file_list "${GREEN}✅ OK:${NC}" "${GREEN}" "log" "${COMPILE_OK_LIST[@]}"
            fi
            if [[ ${#COMPILE_FAIL_LIST[@]} -gt 0 ]] && ! $PASSED_ONLY; then
                format_file_list "${RED}❌ Failed:${NC}" "${RED}" "err_log" "${COMPILE_FAIL_LIST[@]}"
            fi
            if [[ ${#COMPILE_OK_LIST[@]} -eq 0 && ${#COMPILE_FAIL_LIST[@]} -eq 0 ]] && ! $QUIET_MODE; then
                log "    ${DIM}(skipped — using existing binaries)${NC}"
            fi
            log ""
        fi
    fi

    # 2. Test Execution
    if ! $COMPILE_ONLY; then
        if ! $QUIET_MODE || [[ ${#FAILED_LIST[@]} -gt 0 ]]; then
            if ! $BRIEF_SUMMARY; then
                err_log "  ${BOLD}🚀 Test Execution:${NC}"
                if [[ ${#PASS_LIST[@]} -gt 0 ]] && ! $QUIET_MODE && ! $FAILED_ONLY; then
                    format_file_list "${GREEN}✅ Passed:${NC}" "${GREEN}" "log" "${PASS_LIST[@]}"
                fi
                if [[ ${#FAILED_LIST[@]} -gt 0 ]] && ! $PASSED_ONLY; then
                    format_file_list "${RED}❌ Failed:${NC}" "${RED}" "err_log" "${FAILED_LIST[@]}"
                fi
                log ""
            fi
        fi

        # 3. Global Stats (Centered as a unified block)
        MISSING_COUNT=0
        if $STRICT_EXEC; then
            MISSING_COUNT=${#MISSING_BINARIES[@]}
        fi
        
        COMPILE_SUCCESS_COUNT=$(( TOTAL_FILES - COMPILE_ERRORS - MISSING_COUNT ))
        COMPILE_SUCCESS_RATE=0
        if [ $TOTAL_FILES -gt 0 ]; then
            COMPILE_SUCCESS_RATE=$(( (COMPILE_SUCCESS_COUNT * 100) / TOTAL_FILES ))
        fi

        SUCCESS_RATE=0
        TOTAL_AS=$((STAT_AS_PASS + STAT_AS_FAIL))
        AVG_ASSERTIONS=0
        
        if [ $STAT_TC_TOTAL -gt 0 ]; then
            SUCCESS_RATE=$(( (STAT_TC_PASS * 100) / STAT_TC_TOTAL ))
            AVG_ASSERTIONS=$(( TOTAL_AS / STAT_TC_TOTAL ))
        fi
        
        END_TIME=$(date +%s)
        ELAPSED=$((END_TIME - START_TIME))

        # Build the block to display
        STATS_BLOCK="${BOLD}📊 Global Stats${NC}
────────────────────────────────
Compilation Rate: ${BOLD}${CYAN}${COMPILE_SUCCESS_RATE}%${NC} ${DIM}(${COMPILE_SUCCESS_COUNT} of ${TOTAL_FILES})${NC}"

        if $VERBOSE; then
            STATS_BLOCK+="\n  ${DIM}-${NC} ${GREEN}Compiled:${NC} ${COMPILE_SUCCESS_COUNT}\n  ${DIM}-${NC} ${RED}Errors:${NC}   ${COMPILE_ERRORS}"
            if [[ $MISSING_COUNT -gt 0 ]]; then
                STATS_BLOCK+="\n  ${DIM}-${NC} ${YELLOW}Missing:${NC}  ${MISSING_COUNT}"
            fi
        fi

        STATS_BLOCK+="\n
Test Cases:   ${STAT_TC_TOTAL} total | ${GREEN}${STAT_TC_PASS} passed${NC} | ${RED}${STAT_TC_FAIL} failed${NC} | ${DIM}${STAT_TC_SKIP} skipped${NC}
Assertions:   ${TOTAL_AS} total | ${GREEN}${STAT_AS_PASS} passed${NC} | ${RED}${STAT_AS_FAIL} failed${NC}
Success Rate: ${BOLD}${CYAN}${SUCCESS_RATE}%${NC}
────────────────────────────────"

        # if [[ ${#SLOWEST_TESTS[@]} -gt 0 ]]; then
        #     STATS_BLOCK+="\n────────────────────────────────\n${BOLD}🐌 Slowest Tests${NC}"
        #     IFS=$'\n' read -r -d '' -a SORTED_SLOWEST < <(printf "%s\n" "${SLOWEST_TESTS[@]}" | sort -t: -k1 -nr | head -n 3 && printf '\0')
        #     for entry in "${SORTED_SLOWEST[@]}"; do
        #         dur="${entry%%:*}"
        #         name="${entry#*:}"
        #         STATS_BLOCK+="\n  ${name}: ${YELLOW}${dur}s${NC}"
        #     done
        # fi

        if ! $QUIET_MODE; then
            STATS_BLOCK+="\n⏱️  Total Time: ${CYAN}${ELAPSED}s${NC}\n📈 Avg Assertions/Test: ${CYAN}${AVG_ASSERTIONS}${NC}\n────────────────────────────────"
        fi

        echo -e "$STATS_BLOCK" | while IFS= read -r line; do
            echo -e "  ${line}"
        done
    fi

    banner "SUMMARY" "$GREEN"
fi

if [[ -n "$LOGFILE" ]]; then
    echo -e "${CYAN}  📄 Log saved to: $LOGFILE${NC}"
fi

if $REMOVE_TESTS; then
    if $VERBOSE; then
        echo -e "${CYAN}🗑️  Deleting ${EXEC_DIR} directory and all its contents...${NC}"
    fi
    rm -rf "${EXEC_DIR}"
fi

[[ $FAIL -eq 0 && $COMPILE_ERRORS -eq 0 ]]

# ============================================================
#  JSON OUTPUT
# ============================================================
if $JSON_OUTPUT; then
    # Function to escape strings for JSON (minimal for this use case)
    escape_json() {
        echo -n "$1" | sed 's/"/\\"/g'
    }

    # Prepare comma-separated lists for JSON
    json_list() {
        local arr=("$@")
        local out=""
        for item in "${arr[@]}"; do
            out="${out}\"$(escape_json "$item")\","
        done
        echo "${out%,}"
    }

    echo "{"
    echo "  \"version\": \"$VERSION\","
    echo "  \"timestamp\": \"$(date '+%Y-%m-%d %T')\","
    echo "  \"compilation\": {"
    echo "    \"ok\": [$(json_list "${COMPILE_OK_LIST[@]}")],"
    echo "    \"failed\": [$(json_list "${COMPILE_FAIL_LIST[@]}")]"
    echo "  },"
    echo "  \"execution\": {"
    echo "    \"passed\": [$(json_list "${PASS_LIST[@]}")],"
    echo "    \"failed\": [$(json_list "${FAILED_LIST[@]}")]"
    echo "  },"
    echo "  \"stats\": {"
    echo "    \"compilation\": { \"total\": ${TOTAL_FILES:-0}, \"success\": ${COMPILE_SUCCESS_COUNT:-0}, \"errors\": ${COMPILE_ERRORS:-0}, \"missing\": ${MISSING_COUNT:-0}, \"rate\": ${COMPILE_SUCCESS_RATE:-0} },"
    echo "    \"test_cases\": { \"total\": ${STAT_TC_TOTAL:-0}, \"passed\": ${STAT_TC_PASS:-0}, \"failed\": ${STAT_TC_FAIL:-0}, \"skipped\": ${STAT_TC_SKIP:-0} },"
    echo "    \"assertions\": { \"total\": $((STAT_AS_PASS + STAT_AS_FAIL)), \"passed\": ${STAT_AS_PASS:-0}, \"failed\": ${STAT_AS_FAIL:-0} },"
    echo "    \"success_rate\": ${SUCCESS_RATE:-0},"
    echo "    \"elapsed_time\": ${ELAPSED:-0}"
    echo "  }"
    echo "}"
fi
